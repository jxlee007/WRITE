@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@400;500;600&display=swap');

@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    --background: 0 0% 4%;
    --foreground: 0 0% 90%;

    --card: 0 0% 7%;
    --card-foreground: 0 0% 90%;

    --popover: 0 0% 7%;
    --popover-foreground: 0 0% 90%;

    --primary: 155 100% 50%;
    --primary-foreground: 0 0% 4%;

    --secondary: 0 0% 12%;
    --secondary-foreground: 0 0% 90%;

    --muted: 0 0% 14%;
    --muted-foreground: 0 0% 55%;

    --accent: 180 100% 50%;
    --accent-foreground: 0 0% 4%;

    --destructive: 0 84% 60%;
    --destructive-foreground: 0 0% 98%;

    --border: 0 0% 16%;
    --input: 0 0% 16%;
    --ring: 155 100% 50%;

    --radius: 0.375rem;

    --sidebar-background: 0 0% 5%;
    --sidebar-foreground: 0 0% 75%;
    --sidebar-primary: 155 100% 50%;
    --sidebar-primary-foreground: 0 0% 4%;
    --sidebar-accent: 0 0% 10%;
    --sidebar-accent-foreground: 0 0% 90%;
    --sidebar-border: 0 0% 14%;
    --sidebar-ring: 155 100% 50%;

    --wiki-link: 155 100% 50%;
    --wiki-heading: 180 100% 50%;
    --wiki-border-glow: 155 100% 50%;
  }
}

@layer base {
  * {
    @apply border-border;
  }

  body {
    @apply bg-background text-foreground font-serif;
    font-family: 'Lora', Georgia, serif;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'JetBrains Mono', monospace;
  }

  /* Terminal grid background */
  body::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image:
      linear-gradient(hsl(0 0% 100% / 0.02) 1px, transparent 1px),
      linear-gradient(90deg, hsl(0 0% 100% / 0.02) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  /* Scrollbar */
  ::-webkit-scrollbar {
    width: 6px;
  }
  ::-webkit-scrollbar-track {
    background: hsl(0 0% 5%);
  }
  ::-webkit-scrollbar-thumb {
    background: hsl(0 0% 20%);
    border-radius: 3px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: hsl(155 100% 50% / 0.4);
  }
}

/* Wiki content styles */
.wiki-content h1 {
  @apply text-3xl font-bold mb-6 pb-2 border-b border-border;
  color: hsl(var(--wiki-heading));
}
.wiki-content h2 {
  @apply text-2xl font-semibold mt-8 mb-4 pb-1 border-b border-border/50;
  color: hsl(var(--wiki-heading));
}
.wiki-content h3 {
  @apply text-xl font-medium mt-6 mb-3;
  color: hsl(var(--wiki-heading) / 0.85);
}
.wiki-content p {
  @apply mb-4 leading-relaxed text-foreground/90;
}
.wiki-content ul, .wiki-content ol {
  @apply mb-4 pl-6;
}
.wiki-content li {
  @apply mb-1.5 leading-relaxed;
}
.wiki-content ul li {
  list-style-type: '› ';
}
.wiki-content ol li {
  list-style-type: decimal;
}
.wiki-content blockquote {
  @apply border-l-2 pl-4 my-4 italic;
  border-color: hsl(var(--primary));
  color: hsl(var(--muted-foreground));
}
.wiki-content strong {
  color: hsl(var(--foreground));
  font-weight: 600;
}
.wiki-content code {
  @apply px-1.5 py-0.5 rounded text-sm;
  font-family: 'JetBrains Mono', monospace;
  background: hsl(var(--muted));
  color: hsl(var(--primary));
}
.wiki-content a {
  color: hsl(var(--wiki-link));
  text-decoration: none;
  transition: all 0.2s ease;
  border-bottom: 1px solid transparent;
}
.wiki-content a:hover {
  border-bottom-color: hsl(var(--wiki-link));
  text-shadow: 0 0 8px hsl(var(--wiki-link) / 0.4);
}
.wiki-content hr {
  @apply my-6 border-border/50;
}
